# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# App secrets (TDLib api_id/api_hash) — copy secrets_example.dart to set up,
# or generate from .env via scripts/gen-secrets.sh
lib/config/secrets.dart

# Raw local secrets consumed by scripts/gen-secrets.sh: Telegram api_id/api_hash
# + base64 signing keystore & passwords. Never commit.
.env

# Firebase client config. These are generated from repository / Xcode Cloud
# secrets in CI and may exist locally for simulator/device runs.
android/app/google-services.json
ios/Runner/GoogleService-Info.plist

# Native TDLib binaries (large, platform-specific — built via scripts/, see NATIVE.md)
android/app/src/main/jniLibs/
**/tdjson.xcframework/
.tdlib-build/

# One-time working notes (not part of the app)
/CLAUDE.md
/SESSION.md
/TODO.md

